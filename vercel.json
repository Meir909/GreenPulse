{
  "buildCommand": "cd nextjs && npm run build",
  "outputDirectory": "nextjs/.next",
  "installCommand": "cd nextjs && npm install",
  "env": {
    "FLASK_URL": "@flask_url",
    "OPENAI_API_KEY": "@openai_api_key"
  },
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/:path*"
    }
  ]
}
